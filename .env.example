# Salin fail ini kepada `.env` dan ubah nilai mengikut persekitaran anda.
# Untuk deploy systemd, gunakan fail ini sebagai EnvironmentFile (laluan mutlak).

DATABASE_URL=postgres://tsuyu:password@localhost/tsuyu_rag
OLLAMA_URL=http://localhost:11434

# --- Model ---
# PENGELUARAN (perlu GPU ~16GB): qwen3:14b + bge-m3 + reranker.
GEN_MODEL=qwen3:14b
EMBED_MODEL=bge-m3
# Dimensi vektor embedding — MESTI sepadan dengan model: bge-m3=1024, nomic-embed-text=768.
# Jika ditukar, aplikasi akan kosongkan chunk lama; jalankan POST /ingest?force=true selepas itu.
EMBED_DIM=1024
# Mod "thinking" Qwen3: false (matikan, disyorkan untuk RAG), true, atau "default".
GEN_THINK=false
#
# PEMBANGUNAN / mesin CPU-sahaja (laju tanpa GPU) — guna model kecil sebaliknya:
#   GEN_MODEL=qwen3:1.7b
#   EMBED_MODEL=nomic-embed-text
#   EMBED_DIM=768
#   RERANK_ENABLED=false
# Pull: `ollama pull qwen3:1.7b && ollama pull nomic-embed-text`
# Diuji pada i7-3770 (CPU sahaja): satu jawapan RAG ~5-6 saat.

DOCS_DIR=/opt/tsuyu-rag/docs
BIND_ADDR=127.0.0.1:8080

# Fail JSON "kad watak" (persona pembantu) — ditala admin via UI /admin atau terus.
# Jika tiada, persona lalai digunakan. Lihat README §Kad Watak.
CHARACTER_CARD_PATH=/opt/tsuyu-rag/character.json

# Zon waktu untuk paparan TIMESTAMPTZ (ingested_at, created_at). Nama zon IANA.
# Ditetapkan pada sesi DB; nilai disimpan kekal UTC dalaman. Lalai waktu Malaysia.
APP_TIMEZONE=Asia/Kuala_Lumpur

# Pengesahan dua peringkat (header `Authorization: Bearer <key>`):
# - API_KEY        : key PENGGUNA — untuk /chat, /chat/stream, GET /documents.
# - ADMIN_API_KEY  : key ADMIN — untuk /ingest, DELETE /documents/:id, DELETE /sessions/:id.
# Key admin juga boleh akses endpoint pengguna. Jika ADMIN_API_KEY kosong, endpoint admin
# jatuh balik ke API_KEY (mod satu-key). Jika kedua-dua kosong, pengesahan dimatikan.
API_KEY=
ADMIN_API_KEY=

# --- Reranker (cross-encoder) ---
# Servis berasingan dengan endpoint /rerank serasi HuggingFace TEI.
# Matikan dengan RERANK_ENABLED=false jika tiada servis reranker.
RERANK_ENABLED=true
RERANKER_URL=http://localhost:8081
RERANKER_MODEL=bge-reranker-v2-m3

# --- Retrieval ---
# TOP_K   = bilangan chunk akhir dihantar ke LLM.
# RETRIEVE_N = bilangan calon diambil dari pgvector SEBELUM rerank (perlu > TOP_K).
TOP_K=5
RETRIEVE_N=30

# --- Hybrid search (vektor + kata kunci BM25, digabung dengan RRF) ---
# Matikan dengan HYBRID_ENABLED=false untuk guna carian vektor sahaja.
HYBRID_ENABLED=true
# Pemalar k dalam Reciprocal Rank Fusion (lazimnya 60).
RRF_K=60
# Konfigurasi full-text PostgreSQL: 'simple' (tiada stemming, sesuai BM) atau 'english'.
FTS_CONFIG=simple

# --- Memori perbualan ---
# Bila dihidupkan, permintaan /chat yang menyertakan "session_id" akan mengingati
# giliran lampau. Matikan dengan MEMORY_ENABLED=false.
MEMORY_ENABLED=true
# Bilangan mesej terkini (giliran) dimuat sebagai konteks perbualan.
MEMORY_TURNS=6

# --- Guardrail relevansi (anti-halusinasi) ---
# Jika konteks tidak cukup relevan, tolak terus tanpa panggil LLM (jawab "tidak dijumpai").
RELEVANCE_ENABLED=true
# Ambang minimum skor reranker (digunakan bila RERANK_ENABLED=true). Naikkan untuk lebih ketat.
RELEVANCE_MIN_RERANK=0.0
# Ambang maksimum jarak cosine (digunakan bila reranking dimatikan). 0=sama, 2=bertentangan.
RELEVANCE_MAX_DISTANCE=1.0

# --- Ketahanan panggilan Ollama (retry + backoff) ---
# Cubaan semula untuk ralat sementara (sibuk/timeout/5xx). 0 = tiada retry.
OLLAMA_MAX_RETRIES=2
# Tempoh asas backoff (ms), digandakan setiap cubaan: 500, 1000, 2000, ...
OLLAMA_RETRY_BASE_MS=500

# --- Had kadar & saiz permintaan ---
# Bilangan permintaan dibenarkan per IP setiap minit. 0 = had kadar dimatikan.
RATE_LIMIT_RPM=120
# Had saiz badan permintaan (bait). Lalai 2 MiB.
MAX_BODY_BYTES=2097152

# --- Chunking & lain-lain (ada nilai lalai jika dikosongkan) ---
# Ingest membaca DOCS_DIR secara rekursif (termasuk subfolder).
CHUNK_TOKENS=700
CHUNK_OVERLAP=100
EMBED_BATCH_SIZE=16
RUST_LOG=info
